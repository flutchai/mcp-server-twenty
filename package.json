{
  "name": "@flutchai/mcp-server-twenty",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for Twenty CRM — people with full custom field support via dynamic introspection",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "axios": "^1.6.5"
  },
  "devDependencies": {
    "@types/node": "^20.3.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.0",
    "typescript": "^5.1.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.13.0"
}
